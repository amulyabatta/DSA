arr=list(map(int,input().split()))
n=len(arr)
i=-1
for ind in range(n):  # find first zero
    if(arr[ind]==0):
        i=ind
        break
if(i!=-1):
    for j in range(i+1,n):   # move non-zero elements forward
        if(arr[j]!=0):
            arr[i],arr[j]=arr[j],arr[i]   # swaping
            i+=1
print(arr)
