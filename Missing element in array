arr = list(map(int,input().split()))
n = len(arr)
XOR1 = 0
XOR2 = 0

for i in range(n-1):          # loop runs only till n-2
    XOR2 = XOR2 ^ arr[i]      # XOR of array elements
    XOR1 = XOR1 ^ (i+1)       # XOR of numbers 1..n-1

XOR1 = XOR1 ^ n               # add last number n
print(XOR1 ^ XOR2)
