class Solution:
    def insertionSort(self, arr):
        # code here
        n=len(arr)
        i=0
        def insertion_sort(arr,i,n):
            if(i==n):
                return
            j=i
            while(j>0 and arr[j-1]>arr[j]):
                arr[j-1],arr[j]=arr[j],arr[j-1]
                j-=1
            insertion_sort(arr,i+1,n)
        insertion_sort(arr,i,n)
        return arr
