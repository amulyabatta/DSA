# Take input array from user
arr = list(map(int, input().split()))
n = len(arr)

# Initialize maximum sum as negative infinity
maxi = float('-inf')

# Variables to store the start and end indices of the answer subarray
ansStart, ansEnd = -1, -1

# Current running sum
sum = 0

# Traverse the array
for i in range(n):
    # If sum is zero, mark a new possible starting index
    if(sum == 0):
        start = i

    # Add current element to running sum
    sum += arr[i]

    # If we found a better sum, update maximum and store indices
    if(sum > maxi):
        maxi = sum
        ansStart = start
        ansEnd = i

    # If running sum becomes negative, reset it to 0
    if(sum < 0):
        sum = 0

# If all elements are negative, maxi will be < 0
if(maxi < 0):
    print("0")

# Print maximum sum
print(maxi)

# Print the subarray from ansStart to ansEnd
print("[", end=" ")
for i in range(ansStart, ansEnd+1):
    print(arr[i], end=" ")
print("]")
