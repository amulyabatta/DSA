def reverse(arr,start,end):
    while start <= end:
        temp = arr[start]
        arr[start] = arr[end]
        arr[end] = temp
        start += 1
        end -= 1

arr = list(map(int, input().split()))
n = len(arr)
k = int(input())
k = k % n   # handle k > n
reverse(arr, 0, n-1)     # Reverse the whole array
reverse(arr, 0, k-1)     # Reverse first k elements
reverse(arr, k, n-1)     # Reverse remaining n-k elements
print(arr)
