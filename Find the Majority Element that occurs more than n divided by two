arr = list(map(int, input().split()))  
n = len(arr)
c = 0   # counter
for i in range(n):
    if c == 0:          # if counter is 0, choose current element as candidate
        ele = arr[i]
        c += 1
    else:
        if arr[i] == ele:   # if same as candidate, increase count
            c += 1
        else:               # otherwise decrease count
            c -= 1

print(ele)   # majority element (candidate)
