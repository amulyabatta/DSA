freq={}
nums=list(map(int,input().split()))
n=len(nums)
for i in range(len(nums)):
    value=nums[i]
    if value not in freq:
        freq[value]=1
    else:
        freq[value]+=1
max_freq=0
min_freq=n+1
max_ele=None
min_ele=None
for key in freq:
    count=freq[key]
    if count > max_freq:
        max_freq=count
        max_ele=key
    if count < min_freq:
        min_freq=count
        min_ele=key
print(max_ele,min_ele)
