# Input rows and columns
n = int(input())
m = int(input())

# Input matrix
mat = []
for i in range(n):
    lst = list(map(int, input().split()))
    mat.append(lst)

col0 = 1  # Flag to track if first column should be zero

# Step 1: Mark first row and first column
for i in range(n):
    for j in range(m):
        if mat[i][j] == 0:
            mat[i][0] = 0          # Mark first element of the row
            if j != 0:
                mat[0][j] = 0      # Mark first element of the column
            else:
                col0 = 0           # Mark that first column must be zero

# Step 2: Use marks to set inner matrix cells to zero
for i in range(1, n):
    for j in range(1, m):
        if mat[i][0] == 0 or mat[0][j] == 0:
            mat[i][j] = 0

# Step 3: Handle the first row separately
if mat[0][0] == 0:
    for j in range(m):
        mat[0][j] = 0

# Step 4: Handle the first column separately
if col0 == 0:
    for i in range(n):
        mat[i][0] = 0

# Print final matrix
print(mat)
